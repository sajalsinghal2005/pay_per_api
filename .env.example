# ========================================
# API HUB - ENVIRONMENT CONFIGURATION
# ========================================
# 
# SETUP INSTRUCTIONS:
# 1. Copy this file: cp .env.example .env
# 2. Fill in your actual values below
# 3. DO NOT commit .env to git (it's in .gitignore)
# 4. Each team member gets their own .env file
#
# Format Rules:
#   - NO spaces around = (KEY=value, not KEY = value)
#   - NO quotes unless specified
#   - Use full URLs including protocol (https://)
#

# ========================================
# 1. SERVER CONFIGURATION
# ========================================
# Port where the server runs locally
PORT=3001

# Environment mode
# Options: development, production, test
NODE_ENV=development

# ========================================
# 2. EMAIL CONFIGURATION (For OTP & Notifications)
# ========================================
# We use Gmail SMTP for sending emails
#
# HOW TO GET GMAIL APP PASSWORD:
# ─────────────────────────────
# 1. Go to: https://myaccount.google.com
# 2. Click "Security" (left sidebar)
# 3. Enable "2-Step Verification" (if not already enabled)
# 4. Find "App passwords" (appears after 2FA is enabled)
# 5. Select: Mail → Windows Computer
# 6. Google generates a 16-character password
# 7. Copy it below (includes spaces, remove them):
#
#    Example: "xxxx xxxx xxxx xxxx" → "xxxxxxxxxxxxxxxx"
#

# Your Gmail email address
EMAIL_USER=your-email@gmail.com

# 16-character Gmail app password (no spaces!)
# ⚠️ NOT your regular Gmail password
EMAIL_PASS=xxxxxxxxxxxx

# ========================================
# 3. DATABASE CONFIGURATION
# ========================================
# SQLite database file path
# Will be auto-created if doesn't exist
DATABASE_PATH=./app.db

# ========================================
# 4. BLOCKCHAIN CONFIGURATION (Crypto Payments)
# ========================================
# For Monad Testnet - community blockchain for testing
#
# HOW TO GET STARTED:
# ──────────────────
# 1. Install MetaMask: https://metamask.io
# 2. Add Monad Testnet network:
#    - Chain ID: 10143
#    - RPC URL: https://testnet-rpc.monad.xyz/
# 3. Get test ETH from faucet
# 4. Copy your wallet address below
#

# Monad Testnet RPC endpoint
MONAD_RPC_URL=https://testnet-rpc.monad.xyz/

# Your Ethereum wallet address (0x prefixed)
# Get from MetaMask or any Web3 wallet
# Do NOT use a wallet you need real funds in (this is for TESTING)
WALLET_ADDRESS=0xYourEthereumWalletAddressHere

# ========================================
# 5. SESSION & SECURITY CONFIGURATION
# ========================================
# How long before user session expires (in minutes)
SESSION_TIMEOUT=30

# Secret key for signing JWT tokens
# ⚠️ CHANGE THIS in production!
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-key-change-this-in-production-12345

# ========================================
# 6. REAL API INTEGRATIONS
# ========================================
# OpenWeatherMap - Real weather data API
#
# HOW TO GET API KEY:
# ──────────────────
# 1. Visit: https://openweathermap.org/api
# 2. Sign up (free tier available)
# 3. Go to: https://home.openweathermap.org/api_keys
# 4. Copy your API key:
#

# OpenWeatherMap API key (free tier)
# Use this to fetch real weather data by city
WEATHER_API_KEY=your_openweathermap_api_key_here

# ========================================
# 7. FEATURE FLAGS
# ========================================
# Enable Two-Factor Authentication
ENABLE_2FA=true

# Enable payments with cryptocurrency
ENABLE_CRYPTO_PAYMENTS=true

# Enable email notifications
ENABLE_EMAIL_NOTIFICATIONS=true

# ========================================
# QUICK REFERENCE
# ========================================
#
# Test Gmail Setup:
#   npm test-email
#
# Test Weather API:
#   curl "http://localhost:3001/weather?city=london"
#
# Test Blockchain:
#   Requires metamask connected to monad testnet
#
# View Database:
#   sqlite3 app.db
#   .tables
#   SELECT * FROM users;
#
# Reset Database:
#   rm app.db
#   npm start (recreates schema)
#

# Enable automatic credit recharge
ENABLE_AUTO_RECHARGE=true

# Enable email notifications
ENABLE_EMAIL_NOTIFICATIONS=true

# Enable SMS notifications (requires Twilio config)
ENABLE_SMS_NOTIFICATIONS=true

# ==========================================
# API CONFIGURATION
# ==========================================
# Minimum credits threshold for auto-recharge
LOW_CREDIT_THRESHOLD=100

# Default credits on new account signup
DEFAULT_CREDITS=500

# ==========================================
# LOGGING CONFIGURATION
# ==========================================
LOG_LEVEL=debug
# Options: error, warn, info, debug, trace
