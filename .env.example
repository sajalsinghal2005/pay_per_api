# Environment Variables Configuration
# Copy this file to .env and fill in your actual values

# ==========================================
# SERVER CONFIGURATION
# ==========================================
PORT=3001
NODE_ENV=development

# ==========================================
# EMAIL CONFIGURATION (Gmail SMTP)
# ==========================================
# How to get Gmail App Password:
# 1. Enable 2-Step Verification: https://myaccount.google.com
# 2. Go to App Passwords: https://myaccount.google.com/apppasswords
# 3. Select "Mail" and "Windows Computer"
# 4. Copy the 16-character password below
EMAIL_USER=sajalsinghal62650@gmail.com
EMAIL_PASS=yxboxodglarvsvvd

# ==========================================
# DATABASE CONFIGURATION
# ==========================================
DATABASE_PATH=./app.db

# ==========================================
# BLOCKCHAIN CONFIGURATION (Monad Testnet)
# ==========================================
# RPC Endpoint for Monad Testnet
MONAD_RPC_URL=https://testnet-rpc.monad.xyz/

# Your Ethereum wallet address (for receiving crypto payments)
# Example: 0x7894561230987456123098745612309874561230
WALLET_ADDRESS=0xFd370335f04d29D412e48c396953c7bac594d991

# ==========================================
# SESSION & SECURITY CONFIGURATION
# ==========================================
# Session timeout in minutes
SESSION_TIMEOUT=30

# JWT Secret Key (change this to a long random string in production!)
JWT_SECRET=your-super-secret-key-change-this-in-production-12345

# ==========================================
# FEATURE FLAGS
# ==========================================
# Enable Two-Factor Authentication
ENABLE_2FA=true

# Enable automatic credit recharge
ENABLE_AUTO_RECHARGE=true

# Enable email notifications
ENABLE_EMAIL_NOTIFICATIONS=true

# Enable SMS notifications (requires Twilio config)
ENABLE_SMS_NOTIFICATIONS=true

# ==========================================
# API CONFIGURATION
# ==========================================
# Minimum credits threshold for auto-recharge
LOW_CREDIT_THRESHOLD=100

# Default credits on new account signup
DEFAULT_CREDITS=500

# ==========================================
# LOGGING CONFIGURATION
# ==========================================
LOG_LEVEL=debug
# Options: error, warn, info, debug, trace
